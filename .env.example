# QuickQuote environment configuration
# Copy to .env.local (renderer) and .env (server) and fill in values.
# DO NOT commit real values.

# ─────────────────────────────────────────────────────────────────────────────
# Renderer (Vite — variables MUST start with VITE_ to be exposed to the SPA)
# ─────────────────────────────────────────────────────────────────────────────

# If set, the renderer uses the HTTP adapter and points at this URL.
# Leave empty for Electron mode (default during dev today).
VITE_API_BASE_URL=

# Entra ID app registration (single-page app platform)
# From: Azure portal → App Registrations → QuickQuote → Overview
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Custom API scope you exposed in the API app registration.
# Example: api://quickquote-api/access_as_user
VITE_AZURE_SCOPES=

# ─────────────────────────────────────────────────────────────────────────────
# Server (Fastify on Azure App Service)
# ─────────────────────────────────────────────────────────────────────────────

# Azure SQL Database connection string. Prefer managed identity over
# password; if using AAD: Authentication=ActiveDirectoryDefault
AZURE_SQL_CONNECTION_STRING=

# Azure Key Vault reference for ClickUp token. The server reads this name
# from Key Vault at runtime; do not paste the token here.
CLICKUP_TOKEN_KV_REF=

# Azure Blob container URL where generated DOCX/PDF files live.
# Example: https://quickquote.blob.core.windows.net/generated-proposals
BLOB_CONTAINER_URL=

# Entra ID values used to validate incoming JWTs.
# JWT_AUDIENCE = the API app registration's Application ID URI
# JWT_ISSUER   = https://login.microsoftonline.com/<tenant-id>/v2.0
JWT_AUDIENCE=
JWT_ISSUER=

# Server listen port. App Service injects PORT automatically; default 8080.
PORT=8080
